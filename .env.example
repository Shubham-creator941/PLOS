# =============================================================================
# PLOS — Root .env.example  (used by docker-compose.yml)
# =============================================================================
# Copy to .env at the repo root:   cp .env.example .env
# Fill in every CHANGE_ME value before running docker compose.
# =============================================================================

# ── API server port exposed on the host ───────────────────────────────────────
PORT=3000

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_NAME=plos
DB_USER=plos_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_ROOT_PASSWORD=CHANGE_ME_root_password_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# openssl rand -base64 48
JWT_SECRET=CHANGE_ME_minimum_32_char_jwt_secret_here
JWT_EXPIRES_IN=7d
