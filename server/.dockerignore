# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/

# ── Tests (never ship to production image) ─────────────────────────────────────
**/*.spec.ts
**/*.test.ts
jest.config.js
src/__tests__/

# ── Development tooling ────────────────────────────────────────────────────────
.ts-node/
coverage/

# ── Secrets & local configuration ─────────────────────────────────────────────
.env
.env.*
!.env.example

# ── OS / editor artefacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Docker ────────────────────────────────────────────────────────────────────
Dockerfile*
docker-compose*.yml
.dockerignore

# ── Docs (not required at runtime) ───────────────────────────────────────────
docs/
README*
