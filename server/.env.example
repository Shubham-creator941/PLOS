# =============================================================================
# PLOS Backend — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in EVERY value before running.
# NEVER commit .env to version control.
#
#   cp .env.example .env
#
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# The port the API listens on inside the container (and mapped on the host).
PORT=3000

# "development" | "test" | "production"
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# MySQL 8 connection details.
# In Docker Compose the host is the service name: "db"
DB_HOST=db
DB_PORT=3306
DB_NAME=plos
DB_USER=plos_user

# Plain-text password — replace with a strong random value in production.
# Generate one with:  openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_strong_password_here

# Root password used only by Docker Compose to initialise the MySQL container.
DB_ROOT_PASSWORD=CHANGE_ME_root_password_here

# Connection pool limits
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_ACQUIRE_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=10000

# ── Authentication ────────────────────────────────────────────────────────────
# HS256 signing secret for JSON Web Tokens.
# Minimum 32 characters.  Generate with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_minimum_32_char_jwt_secret_here

# Standard JWT duration string understood by jsonwebtoken (e.g. 7d, 24h, 3600)
JWT_EXPIRES_IN=7d

# ── File Uploads ──────────────────────────────────────────────────────────────
# Absolute path INSIDE the container where uploaded files are stored.
# Mount a Docker volume to this path to persist uploads across restarts.
UPLOAD_DIR=/app/uploads

# Maximum file size accepted by multer (bytes).  Default: 10 MB
UPLOAD_MAX_SIZE_BYTES=10485760

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use "*" only for fully-public APIs.
CORS_ORIGIN=http://localhost:5173,https://app.example.com

# ── Logging ───────────────────────────────────────────────────────────────────
# "error" | "warn" | "info" | "debug"
LOG_LEVEL=info

# ── Rate Limiting (optional) ──────────────────────────────────────────────────
# Requests per IP per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
